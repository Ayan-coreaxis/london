APP_NAME="London InstantPrint"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://londoninstantprint.co.uk

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=london_instantprint
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ─── MAIL SETTINGS (REQUIRED for emails to work) ───────────────
# For production use SMTP (e.g. Gmail, Mailgun, SendGrid, etc.)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=your_mailgun_username
MAIL_PASSWORD=your_mailgun_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@londoninstantprint.co.uk
MAIL_FROM_NAME="London InstantPrint"

# Admin email (contact form messages go here)
MAIL_ADMIN_ADDRESS=info@londoninstantprint.co.uk

# ─── SESSION ────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# ─── For local dev only — use log to test emails without SMTP ───
# MAIL_MAILER=log
